{
  "name": "server",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsdown",
    "check-types": "tsc -b",
    "dev": "tsx watch --env-file=.env src/index.ts",
    "start": "node --env-file=.env --import ./dist/instrument.js dist/index.js",
    "deploy": "pnpm --filter @alfred/db db:migrate"
  },
  "dependencies": {
    "@alfred/ai": "workspace:*",
    "@alfred/api": "workspace:*",
    "@alfred/contracts": "workspace:*",
    "@alfred/db": "workspace:*",
    "@alfred/env": "workspace:*",
    "@alfred/ingestion": "workspace:*",
    "@alfred/integrations": "workspace:*",
    "@alfred/mailer": "workspace:*",
    "@elysiajs/cors": "catalog:",
    "@elysiajs/node": "catalog:",
    "@sentry/node": "catalog:",
    "drizzle-orm": "^0.45.2",
    "elysia": "catalog:",
    "isomorphic-dompurify": "^2.36.0",
    "jsdom": "^28.1.0",
    "sharp": "^0.35.2",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@ai-sdk/anthropic": "catalog:",
    "@ai-sdk/google": "catalog:",
    "@alfred/config": "workspace:*",
    "@types/node": "catalog:",
    "@types/react": "^19.0.0",
    "tsdown": "catalog:",
    "tsx": "^4.19.2",
    "typescript": "catalog:"
  }
}
