# Database
DATABASE_URL=postgresql://alfred:alfred@localhost:5432/alfred

# Redis
REDIS_URL=redis://localhost:6379

# Better Auth
BETTER_AUTH_SECRET=change-me-to-a-random-32-char-string-min
BETTER_AUTH_URL=http://localhost:3001

# CORS
CORS_ORIGIN=http://localhost:3000

# Allowlist of emails permitted to sign up (comma-separated; one is fine)
ALFRED_ALLOWED_EMAIL=your@email.com,teammate@example.com

# Resend (transactional email: briefings, approvals, skill docs)
RESEND_API_KEY=re_xxxx
RESEND_FROM_EMAIL=Alfred <noreply@example.com>

# AI providers
ANTHROPIC_API_KEY=sk-ant-xxxx
GOOGLE_GENERATIVE_AI_API_KEY=AIxxxx
OPENAI_API_KEY=sk-xxxx  # optional

# Embedding + search
VOYAGE_API_KEY=  # optional until milestone 7
PERPLEXITY_API_KEY=  # optional

# User-model substrate (ADR-0067). HMAC namespace for content-addressed stable
# entity IDs. Optional now (no projection writes IDs yet); P1 fails closed if
# absent. Back it up like an auth secret — changing it remints every entity ID.
ENTITY_ID_NAMESPACE=  # optional until ADR-0067 P1; >=32 chars, no surrounding whitespace when set

# Google integration (m7)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3001/api/integrations/google/callback
# Pub/Sub for Gmail push (m7c). Topic must exist and grant
# `roles/pubsub.publisher` to gmail-api-push@system.gserviceaccount.com.
GOOGLE_PUBSUB_TOPIC=  # projects/<id>/topics/gmail-push
GOOGLE_PUBSUB_AUDIENCE=  # required in prod; OIDC audience set on the push subscription (any URL)
GOOGLE_PUBSUB_SERVICE_ACCOUNT=  # required in prod; service-account email expected in OIDC token
# Gmail mailbox-write gate (#278). Dev and prod share one real Gmail account;
# leave UNSET locally so non-prod never writes labels or (un)installs the watch
# and fights prod over the mailbox (default: on in production, off otherwise).
# Set "true" to deliberately opt a dev box into real Gmail writes.
GMAIL_MAILBOX_WRITES_ENABLED=

# GitHub App (ADR-0052) — register at https://github.com/settings/apps/new
# (easiest via the manifest flow; see docs/reference/auth.md). The App's
# user-to-server OAuth provides identity; installation tokens (APP_ID +
# PRIVATE_KEY) provide REST access; WEBHOOK_SECRET verifies activity webhooks.
# Callback URL: http://localhost:3001/api/integrations/github/callback
# Webhook URL (prod only): https://<server-domain>/webhooks/github
GITHUB_APP_ID=
GITHUB_APP_SLUG=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
# PEM with newlines escaped as literal \n on a single line.
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=
GITHUB_APP_REDIRECT_URI=http://localhost:3001/api/integrations/github/callback

# Notion OAuth integration (optional; connect route returns 503 if unset)
NOTION_OAUTH_CLIENT_ID=
NOTION_OAUTH_CLIENT_SECRET=
NOTION_OAUTH_REDIRECT_URI=http://localhost:3001/api/integrations/notion/callback

# Vercel OAuth integration (optional; connect route returns 503 if unset)
VERCEL_CLIENT_ID=
VERCEL_CLIENT_SECRET=
VERCEL_REDIRECT_URI=http://localhost:3001/api/integrations/vercel/callback
VERCEL_APP_SLUG=

# Observability (all optional)
# Server-side Sentry (@sentry/node), read via serverEnv().
SENTRY_DSN=
# Web-side Sentry (@sentry/react). MUST be VITE_-prefixed to reach the browser
# bundle, and lives in apps/web/.env (not this file). The client DSN is public.
VITE_SENTRY_DSN=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
# Opt-in: attach full prompt/completion text to Langfuse spans. Anything other
# than "true" is off. Leave it false in prod — prod points at metered Langfuse
# Cloud and the prompts carry user PII. Enable only on a local/self-hosted box.
LANGFUSE_CAPTURE_IO=false
# Langfuse Environments slug for this deploy target. NODE_ENV=production on
# every deploy target (staging/preview/prod), so set this to keep their traces
# apart. Lowercase [a-z0-9-_], max 40 chars, can't start with "langfuse";
# falls back to NODE_ENV when unset.
LANGFUSE_TRACING_ENVIRONMENT=
# To point at the local self-hosted stack (docker/langfuse/docker-compose.yml),
# uncomment these — they match the compose seed — and set CAPTURE_IO=true:
#   LANGFUSE_HOST=http://localhost:3100
#   LANGFUSE_PUBLIC_KEY=pk-lf-0fc539ee-ece8-4462-bc7a-4a3f7ddcc4ce
#   LANGFUSE_SECRET_KEY=sk-lf-baded212-83c2-4b3c-a0f4-46dc80bf823f
POSTHOG_API_KEY=
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com

# Chat file uploads (Cloudflare R2 / S3-compatible)
# Create an R2 bucket + an R2 API token, then fill these in.
CHAT_S3_BUCKET=
CHAT_S3_REGION=auto
CHAT_S3_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
CHAT_S3_ACCESS_KEY_ID=
CHAT_S3_SECRET_ACCESS_KEY=
# Optional: only set for an R2 custom-domain/CDN front. Private R2 buckets leave this blank.
CHAT_S3_PUBLIC_BASE_URL=
# Optional: leave false for R2 (virtual-hosted on the account endpoint works).
CHAT_S3_FORCE_PATH_STYLE=false

# Node env
NODE_ENV=development

# Web (Vite)
VITE_API_URL=http://localhost:3001
