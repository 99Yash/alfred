# Database
DATABASE_URL=postgresql://alfred:alfred@localhost:5432/alfred

# Redis
REDIS_URL=redis://localhost:6379

# Better Auth
BETTER_AUTH_SECRET=change-me-to-a-random-32-char-string-min
BETTER_AUTH_URL=http://localhost:3001

# CORS
CORS_ORIGIN=http://localhost:3000

# Allowlist of emails permitted to sign up (comma-separated; one is fine)
ALFRED_ALLOWED_EMAIL=your@email.com,teammate@example.com

# Resend (for magic link emails)
RESEND_API_KEY=re_xxxx
RESEND_FROM_EMAIL=Alfred <noreply@example.com>

# AI providers
ANTHROPIC_API_KEY=sk-ant-xxxx
GOOGLE_GENERATIVE_AI_API_KEY=AIxxxx
OPENAI_API_KEY=sk-xxxx  # optional

# Embedding + search
VOYAGE_API_KEY=  # optional until milestone 7
PERPLEXITY_API_KEY=  # optional

# User-model substrate (ADR-0067). HMAC namespace for content-addressed stable
# entity IDs. Optional now (no projection writes IDs yet); P1 fails closed if
# absent. Back it up like an auth secret — changing it remints every entity ID.
ENTITY_ID_NAMESPACE=  # optional until ADR-0067 P1; >=32 chars when set

# Google integration (m7)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3001/api/integrations/google/callback
# Pub/Sub for Gmail push (m7c). Topic must exist and grant
# `roles/pubsub.publisher` to gmail-api-push@system.gserviceaccount.com.
GOOGLE_PUBSUB_TOPIC=  # projects/<id>/topics/gmail-push
GOOGLE_PUBSUB_AUDIENCE=  # OIDC audience set on the push subscription (any URL)
GOOGLE_PUBSUB_SERVICE_ACCOUNT=  # optional: service-account email expected in OIDC token

# GitHub App (ADR-0052) — register at https://github.com/settings/apps/new
# (easiest via the manifest flow; see docs/reference/auth.md). The App's
# user-to-server OAuth provides identity; installation tokens (APP_ID +
# PRIVATE_KEY) provide REST access; WEBHOOK_SECRET verifies activity webhooks.
# Callback URL: http://localhost:3001/api/integrations/github/callback
# Webhook URL (prod only): https://<server-domain>/webhooks/github
GITHUB_APP_ID=
GITHUB_APP_SLUG=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
# PEM with newlines escaped as literal \n on a single line.
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=
GITHUB_APP_REDIRECT_URI=http://localhost:3001/api/integrations/github/callback

# Observability (all optional)
SENTRY_DSN=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
# Opt-in: attach full prompt/completion text to Langfuse spans. Anything other
# than "true" is off. Leave it false in prod — prod points at metered Langfuse
# Cloud and the prompts carry user PII. Enable only on a local/self-hosted box.
LANGFUSE_CAPTURE_IO=false
# To point at the local self-hosted stack (docker/langfuse/docker-compose.yml),
# uncomment these — they match the compose seed — and set CAPTURE_IO=true:
#   LANGFUSE_HOST=http://localhost:3100
#   LANGFUSE_PUBLIC_KEY=pk-lf-0fc539ee-ece8-4462-bc7a-4a3f7ddcc4ce
#   LANGFUSE_SECRET_KEY=sk-lf-baded212-83c2-4b3c-a0f4-46dc80bf823f
POSTHOG_API_KEY=

# Chat file uploads (Railway storage bucket / S3-compatible)
# On Railway, map these from the bucket service's injected variables.
CHAT_S3_BUCKET=
CHAT_S3_REGION=auto
CHAT_S3_ENDPOINT=https://storage.railway.app
CHAT_S3_ACCESS_KEY_ID=
CHAT_S3_SECRET_ACCESS_KEY=
# Optional: only set for a CDN/public bucket. Private Railway buckets should leave this blank.
CHAT_S3_PUBLIC_BASE_URL=
# Optional: set true only if the storage provider requires path-style URLs.
CHAT_S3_FORCE_PATH_STYLE=false

# Node env
NODE_ENV=development

# Web (Vite)
VITE_API_URL=http://localhost:3001
