{
  "name": "@alfred/api",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./src/index.ts"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "default": "./src/*.ts"
    }
  },
  "type": "module",
  "scripts": {
    "build": "tsdown",
    "check-types": "tsc -b"
  },
  "devDependencies": {
    "@alfred/config": "workspace:*",
    "tsdown": "catalog:"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@alfred/auth": "workspace:*",
    "@alfred/db": "workspace:*",
    "@alfred/env": "workspace:*",
    "@alfred/sync": "workspace:*",
    "bullmq": "catalog:",
    "drizzle-orm": "^0.45.2",
    "elysia": "catalog:",
    "ioredis": "catalog:",
    "zod": "catalog:"
  }
}
