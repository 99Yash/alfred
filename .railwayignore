# Heavyweight local artifacts not needed in prod builds.
# Exception: apps/web imports references/dimension-dev/artifact-html/**/*.html?raw
# at build time (see apps/web/src/lib/artifact-pages.ts), so that subtree must
# ship. Re-include it via gitignore-style negation — parents have to be
# re-included too for the leaf negation to take effect.
references/*
!references/dimension-dev
references/dimension-dev/*
!references/dimension-dev/artifact-html
.warden/
.tmp/
*.log

# Loops + plans — local-only working files.
plan.md
PRD.md
progress.txt
*-plan.md
*-progress.txt
*-loop.sh
ralph.sh

# Misc dev tooling output.
.cache/
coverage/
